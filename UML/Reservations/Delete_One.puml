@startuml Manage Reservation (DELETE)

header Sameple VacQ Sequence Diagram
footer Page %page% of %lastpage%
title "Delete One Reservation (DELETE)"

skinparam dpi 180
skinparam ParticipantPadding 30
skinparam MessagePadding 25
skinparam maxMessageSize 40

participant "Client" as client
participant "<<javaScript>>\n:server" as server
participant "<<router>>\n:reservations" as routerReservations
participant "<<middleware>>\n:auth/protect" as middleware
participant "<<controllers>>\n:reservations" as controllersReservations
participant "<<controllers>>\n:users" as controllersUsers   
participant "<<model>>\n:Reservation" as modelReservation
participant "<<model>>\n:User" as modelUser
database "<<MongoDB>>\n:reservations" as ReservationsDatabase
database "<<MongoDB>>\n:users" as UsersDatabase

client -> server ++: req.delete('/api/v1/reservations/:id')
server -> routerReservations ++: req.delete('/api/v1/reservations/:id')
routerReservations -> middleware ++: protect(token)
middleware -> modelUser ++: findById(decoded.id)
modelUser -> UsersDatabase ++: findById(decoded.id)
UsersDatabase --> middleware --: user
middleware --> routerReservations --: next()

routerReservations -> middleware ++: authorize('user', 'admin')
middleware --> routerReservations --: next()

routerReservations -> controllersReservations ++: deleteReservation()

controllersReservations -> modelReservation ++: deleteOne(id: req.params.id)

note right of controllersReservations
reponse depends on:
- user only allow to delete their own reserve
- admin can delete any reserve
end note

modelReservation -> ReservationsDatabase ++: ReservationSchema
ReservationsDatabase --> modelReservation --: reservation
modelReservation --> controllersReservations --: reservation

controllersReservations --> client --: response

@enduml